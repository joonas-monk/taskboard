# TaskBoard — Environment Variable Documentation
# Copy this file to .env.production and fill in real values before deploying.
# This file is committed to git. Do NOT put real secrets here.

# SQLite database path (absolute path — must be outside the project directory)
DATABASE_URL=file:/var/data/taskboard/tasks.db

# Anthropic API key — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# AI model used for the pipeline (optional — defaults to this value)
PIPELINE_MODEL=claude-3-5-haiku-20241022

# Node.js environment
NODE_ENV=production

# Port the Next.js server listens on
PORT=3000

# Bind address — 127.0.0.1 means only Nginx can reach the app (do NOT use 0.0.0.0)
HOSTNAME=127.0.0.1
